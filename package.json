{
  "name": "wklej-net",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:public && wrangler dev",
    "deploy": "npm run build:public && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:public && wrangler deploy --dry-run --outdir dist",
    "build:public": "node scripts/build-public.mjs",
    "types": "wrangler types",
    "build:atlas": "node scripts/build-atlas.mjs",
    "verify:client": "npm run build:public && node scripts/client-checksums.mjs",
    "sync:animated": "node scripts/sync-animated-emoji.mjs && npm run build:atlas",
    "refresh:animated-manifest": "node scripts/update-animated-emoji-manifest.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260722.1",
    "esbuild": "^0.28.0",
    "playwright": "^1.60.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.113.0"
  },
  "overrides": {
    "sharp": "^0.35.3"
  }
}
